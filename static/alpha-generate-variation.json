{
    "openapi": "3.0.3",
    "info": {
        "title": "Express API",
        "description": "Express API to automate bulk creation, export renditions and various other use cases.",
        "version": "alpha",
        "contact": {
            "name": "Express API support",
            "email": "express-api-support@adobe.com"
